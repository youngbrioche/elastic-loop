{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/blog/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--rg-accent",
      "--rg-accent-hover",
      "--rg-accent-soft",
      "--rg-bg-1",
      "--rg-bg-2",
      "--rg-bg-3",
      "--rg-body",
      "--rg-border",
      "--rg-border-strong",
      "--rg-content-width",
      "--rg-display",
      "--rg-dur",
      "--rg-ease",
      "--rg-fg-1",
      "--rg-fg-2",
      "--rg-fg-3",
      "--rg-fg-on-accent",
      "--rg-font-mono",
      "--rg-font-sans",
      "--rg-gutter",
      "--rg-h1",
      "--rg-h2",
      "--rg-h3",
      "--rg-kicker",
      "--rg-lead",
      "--rg-lh-body",
      "--rg-lh-snug",
      "--rg-lh-tight",
      "--rg-ls-kicker",
      "--rg-ls-tight",
      "--rg-meta",
      "--rg-nav",
      "--rg-radius-md",
      "--rg-radius-pill",
      "--rg-radius-sm",
      "--rg-shadow-lg",
      "--rg-shadow-md",
      "--rg-shadow-sm",
      "--rg-subtitle",
      "--rg-w-bold",
      "--rg-w-heavy",
      "--rg-w-medium",
      "--rg-w-regular",
      "--rg-w-semibold",
      "--rg-wide-width"
    ],
    "tokenKinds": {
      "--rg-accent": "color",
      "--rg-accent-hover": "color",
      "--rg-accent-soft": "color",
      "--rg-fg-1": "color",
      "--rg-fg-2": "color",
      "--rg-fg-3": "color",
      "--rg-fg-on-accent": "color",
      "--rg-bg-1": "color",
      "--rg-bg-2": "color",
      "--rg-bg-3": "color",
      "--rg-border": "color",
      "--rg-border-strong": "color",
      "--rg-font-sans": "font",
      "--rg-font-mono": "font",
      "--rg-display": "spacing",
      "--rg-h1": "spacing",
      "--rg-h2": "spacing",
      "--rg-h3": "spacing",
      "--rg-subtitle": "spacing",
      "--rg-lead": "spacing",
      "--rg-body": "spacing",
      "--rg-nav": "spacing",
      "--rg-meta": "spacing",
      "--rg-kicker": "spacing",
      "--rg-w-regular": "other",
      "--rg-w-medium": "other",
      "--rg-w-semibold": "other",
      "--rg-w-bold": "other",
      "--rg-w-heavy": "other",
      "--rg-lh-tight": "other",
      "--rg-lh-snug": "other",
      "--rg-lh-body": "other",
      "--rg-ls-kicker": "spacing",
      "--rg-ls-tight": "spacing",
      "--rg-radius-sm": "radius",
      "--rg-radius-md": "radius",
      "--rg-radius-pill": "radius",
      "--rg-shadow-sm": "shadow",
      "--rg-shadow-md": "shadow",
      "--rg-shadow-lg": "shadow",
      "--rg-content-width": "spacing",
      "--rg-wide-width": "spacing",
      "--rg-gutter": "spacing",
      "--rg-ease": "other",
      "--rg-dur": "other"
    },
    "fontFamilies": [
      "Inter"
    ]
  }
}