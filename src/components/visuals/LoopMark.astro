---
interface Props {
  size?: number;
}
const { size = 34 } = Astro.props;
const height = (size * 33) / 34;
---

<svg
  width={size}
  height={height}
  class="loop-mark"
  viewBox="0 0 120 116"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <mask id="elnav-loose" maskUnits="userSpaceOnUse" x="-14" y="-14" width="148" height="144">
      <rect x="-14" y="-14" width="148" height="144" fill="#fff"></rect>
      <ellipse cx="46" cy="70" rx="30" ry="27" transform="rotate(-8 46 70)" fill="none" stroke="#000" stroke-width="10.4" stroke-linecap="round"></ellipse>
    </mask>
    <mask id="elnav-elastic" maskUnits="userSpaceOnUse" x="-14" y="-14" width="148" height="144">
      <rect x="-14" y="-14" width="148" height="144" fill="#fff"></rect>
      <ellipse cx="62" cy="40" rx="22" ry="20" transform="rotate(0 62 40)" fill="none" stroke="#000" stroke-width="10.0" stroke-linecap="round"></ellipse>
    </mask>
    <mask id="elnav-tight" maskUnits="userSpaceOnUse" x="-14" y="-14" width="148" height="144">
      <rect x="-14" y="-14" width="148" height="144" fill="#fff"></rect>
      <ellipse cx="76" cy="70" rx="38" ry="34" transform="rotate(10 76 70)" fill="none" stroke="#000" stroke-width="10.0" stroke-linecap="round"></ellipse>
    </mask>
  </defs>
  <ellipse cx="76" cy="70" rx="38" ry="34" transform="rotate(10 76 70)" fill="none" stroke="#000" stroke-width="6.4" stroke-linecap="round" mask="url(#elnav-loose)"></ellipse>
  <ellipse cx="46" cy="70" rx="30" ry="27" transform="rotate(-8 46 70)" fill="none" stroke="#000" stroke-width="6.4" stroke-linecap="round" mask="url(#elnav-elastic)"></ellipse>
  <ellipse cx="62" cy="40" rx="22" ry="20" transform="rotate(0 62 40)" fill="none" stroke="#000" stroke-width="6.4" stroke-linecap="round" mask="url(#elnav-tight)"></ellipse>
</svg>

<style>
  .loop-mark {
    display: block;
    flex: 0 0 auto;
  }
</style>
