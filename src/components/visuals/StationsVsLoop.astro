---
// Stations versus loop: the old handoff line (PO→UX→Eng→QA→Ops) on the left,
// the same people gathered around a central loop on the right.
// Final agreed layout (v4), ported to project tokens.
---

<figure class="wide stations-vs-loop">
  <div class="matrix-scroll">
    <svg viewBox="0 0 960 560" width="100%" role="img" aria-labelledby="svl-title svl-desc" preserveAspectRatio="xMidYMid meet">
      <title id="svl-title">Stations versus loop</title>
      <desc id="svl-desc">Left: the old sequence of roles as a handoff line, PO to UX to Engineering to QA to Ops, drawn in neutral grey. Right: the same people gathered around a central loop running six uniform steps, each role labelled with the backpressure it supplies, in mint-emerald accent.</desc>
      <defs>
        <marker id="svl-openGrey" markerWidth="11" markerHeight="11" refX="7" refY="4.5" orient="auto" markerUnits="userSpaceOnUse">
          <path d="M2,2 L7,4.5 L2,7" fill="none" stroke="var(--rg-fg-3)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </marker>
      </defs>
      <rect class="svl-frame" x="1" y="1" width="958" height="558" rx="8"/>
      <g>
        <text x="48" y="56" class="svl-kicker svl-grey">Before</text>
        <text x="48" y="82" class="svl-title">The handoff line</text>
        <text x="48" y="106" class="svl-bp" font-size="12.5">Roles queue along the work, one station at a time.</text>
        <g>
          <rect class="svl-station" x="48" y="240" width="58" height="56" rx="6"/>
          <text x="77" y="266" text-anchor="middle" class="svl-role svl-role-grey">PO</text>
          <text x="77" y="284" text-anchor="middle" class="svl-bp" font-size="9.5">formulates</text>
          <line x1="112" y1="268" x2="139" y2="268" class="svl-line-grey" marker-end="url(#svl-openGrey)"/>
          <rect class="svl-station" x="152" y="240" width="58" height="56" rx="6"/>
          <text x="181" y="266" text-anchor="middle" class="svl-role svl-role-grey">UX</text>
          <text x="181" y="284" text-anchor="middle" class="svl-bp" font-size="9.5">designs</text>
          <line x1="216" y1="268" x2="243" y2="268" class="svl-line-grey" marker-end="url(#svl-openGrey)"/>
          <rect class="svl-station" x="256" y="240" width="58" height="56" rx="6"/>
          <text x="285" y="266" text-anchor="middle" class="svl-role svl-role-grey">Eng</text>
          <text x="285" y="284" text-anchor="middle" class="svl-bp" font-size="9.5">builds</text>
          <line x1="320" y1="268" x2="347" y2="268" class="svl-line-grey" marker-end="url(#svl-openGrey)"/>
          <rect class="svl-station" x="360" y="240" width="58" height="56" rx="6"/>
          <text x="389" y="266" text-anchor="middle" class="svl-role svl-role-grey">QA</text>
          <text x="389" y="284" text-anchor="middle" class="svl-bp" font-size="9.5">checks</text>
        </g>
        <line x1="389" y1="296" x2="389" y2="336" class="svl-line-dashed" marker-end="url(#svl-openGrey)"/>
        <rect class="svl-station svl-station-dashed" x="360" y="338" width="58" height="56" rx="6"/>
        <text x="389" y="364" text-anchor="middle" class="svl-role svl-role-muted">Ops</text>
        <text x="389" y="382" text-anchor="middle" class="svl-bp svl-bp-muted" font-size="9.5">learns later</text>
        <text x="48" y="438" class="svl-bp svl-bp-muted" font-size="12.5">Each step expensive enough to deserve its own station.</text>
      </g>
      <line x1="480" y1="40" x2="480" y2="500" class="svl-vrule"/>
      <g>
        <text x="532" y="56" class="svl-kicker svl-mint">After</text>
        <text x="532" y="82" class="svl-title">Gathered around the loop</text>
        <text x="532" y="106" class="svl-bp" font-size="12.5">AI materializes the intermediate steps. Each role brings judgment no one else can.</text>
        <circle class="svl-loop-fill" cx="716" cy="300" r="96"/>
        <circle class="svl-loop-ring" cx="716" cy="300" r="96"/>
        <path class="svl-loop-tick" d="M760.6,209.7 L764,217 L756,217.7"/>
        <circle class="svl-loop-dot" cx="716" cy="204" r="3.5"/>
        <circle class="svl-loop-dot" cx="799" cy="252" r="3.5"/>
        <circle class="svl-loop-dot" cx="799" cy="348" r="3.5"/>
        <circle class="svl-loop-dot" cx="716" cy="396" r="3.5"/>
        <circle class="svl-loop-dot" cx="633" cy="348" r="3.5"/>
        <circle class="svl-loop-dot" cx="633" cy="252" r="3.5"/>
        <g class="svl-step">
          <text x="716" y="225" text-anchor="middle">intent</text>
          <text x="783" y="260" text-anchor="end">context</text>
          <text x="783" y="343" text-anchor="end">variants</text>
          <text x="716" y="381" text-anchor="middle">verification</text>
          <text x="649" y="343" text-anchor="start">decision</text>
          <text x="649" y="256" text-anchor="start">production</text>
          <text x="649" y="268" text-anchor="start">learning</text>
        </g>
        <text x="716" y="305" text-anchor="middle" class="svl-center-word">the loop</text>
        <circle class="svl-role-dot" cx="648" cy="232" r="4"/>
        <text x="600" y="170" text-anchor="middle" class="svl-role svl-role-mint">Product Owner</text>
        <text x="600" y="186" text-anchor="middle" class="svl-bp">intent + grading material:</text>
        <text x="600" y="200" text-anchor="middle" class="svl-bp">acceptance scenarios,</text>
        <text x="600" y="214" text-anchor="middle" class="svl-bp">counterexamples</text>
        <circle class="svl-role-dot" cx="784" cy="232" r="4"/>
        <text x="836" y="170" text-anchor="middle" class="svl-role svl-role-mint">Engineer</text>
        <text x="836" y="186" text-anchor="middle" class="svl-bp">designs the loop and</text>
        <text x="836" y="200" text-anchor="middle" class="svl-bp">harness; verification</text>
        <circle class="svl-role-dot" cx="812" cy="300" r="4"/>
        <text x="878" y="296" text-anchor="middle" class="svl-role svl-role-mint">Designer</text>
        <text x="878" y="312" text-anchor="middle" class="svl-bp">brand &amp; voice,</text>
        <text x="878" y="326" text-anchor="middle" class="svl-bp">design system</text>
        <text x="878" y="340" text-anchor="middle" class="svl-bp">as constraint</text>
        <circle class="svl-role-dot" cx="784" cy="368" r="4"/>
        <text x="836" y="426" text-anchor="middle" class="svl-role svl-role-mint">Domain Expert</text>
        <text x="836" y="442" text-anchor="middle" class="svl-bp">edge cases, golden</text>
        <text x="836" y="456" text-anchor="middle" class="svl-bp">examples &amp; counter-</text>
        <text x="836" y="470" text-anchor="middle" class="svl-bp">examples</text>
        <circle class="svl-role-dot" cx="648" cy="368" r="4"/>
        <text x="600" y="426" text-anchor="middle" class="svl-role svl-role-mint">Process &amp; coaching</text>
        <text x="600" y="442" text-anchor="middle" class="svl-bp">organizational</text>
        <text x="600" y="456" text-anchor="middle" class="svl-bp">loop closure</text>
        <circle class="svl-role-dot" cx="620" cy="300" r="4"/>
        <text x="556" y="296" text-anchor="middle" class="svl-role svl-role-mint">Eng. Leader</text>
        <text x="556" y="312" text-anchor="middle" class="svl-bp">where back-</text>
        <text x="556" y="326" text-anchor="middle" class="svl-bp">pressure</text>
        <text x="556" y="340" text-anchor="middle" class="svl-bp">investment goes</text>
      </g>
      <line x1="48" y1="500" x2="912" y2="500" class="svl-divider"/>
      <text x="48" y="528" class="svl-caption">AI materializes the intermediate steps, so the roles stop queueing along the work and start surrounding it.</text>
    </svg>
  </div>
  <figcaption>Stations versus loop: the roles stop queueing along the work and start surrounding it.</figcaption>
</figure>

<style>
  .stations-vs-loop {
    padding: 0;
  }
  .stations-vs-loop svg {
    display: block;
    font-family: var(--rg-font-sans);
  }

  .svl-frame { fill: var(--rg-bg-1); stroke: var(--rg-border); stroke-width: 1; }

  .svl-kicker { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .svl-grey { fill: var(--rg-fg-3); }
  .svl-mint { fill: var(--rg-accent-hover); }
  .svl-title { font-size: 19px; font-weight: 700; fill: var(--rg-fg-1); }

  .svl-role { font-size: 13.5px; font-weight: 700; fill: var(--rg-fg-1); }
  .svl-role-grey { fill: var(--rg-fg-2); }
  .svl-role-muted { fill: var(--rg-fg-3); }
  .svl-role-mint { fill: var(--rg-fg-1); }

  .svl-bp { font-size: 11.5px; font-weight: 400; fill: var(--rg-fg-2); }
  .svl-bp-muted { fill: var(--rg-fg-3); }

  .svl-center-word { font-size: 12.5px; font-weight: 700; fill: var(--rg-fg-1); }
  .svl-caption { font-size: 14px; font-weight: 400; fill: var(--rg-fg-3); }
  .svl-vrule { stroke: var(--rg-border); stroke-width: 1; }
  .svl-divider { stroke: var(--rg-border); stroke-width: 1; }

  .svl-station { fill: var(--rg-bg-1); stroke: var(--rg-border-strong); stroke-width: 1.4; }
  .svl-station-dashed { stroke-dasharray: 5 4; }
  .svl-line-grey { stroke: var(--rg-fg-3); stroke-width: 1.6; }
  .svl-line-dashed { stroke: var(--rg-border-strong); stroke-width: 1; stroke-dasharray: 4 4; }

  .svl-loop-fill { fill: var(--rg-accent-soft); }
  .svl-loop-ring { fill: none; stroke: var(--rg-accent); stroke-width: 2.5; }
  .svl-loop-tick { fill: none; stroke: var(--rg-accent-hover); stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .svl-loop-dot { fill: var(--rg-accent-hover); }
  .svl-step { fill: var(--rg-accent-hover); font-size: 10.5px; font-weight: 600; }
  .svl-role-dot { fill: var(--rg-accent); }

  figcaption {
    font-size: 14px;
    color: var(--rg-fg-3);
    margin-top: 14px;
  }

  @media (max-width: 980px) {
    .matrix-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 8px;
    }
    .matrix-scroll > * {
      min-width: 860px;
    }
  }
</style>
