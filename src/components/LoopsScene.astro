---
import { Image } from 'astro:assets';
import loopsImg from '../assets/loops.webp';
---

{/*
  Decorative key visual for the Loops page, in the same rendered-3D style as the
  hero: three pool-noodle loops of increasing size with miniature figures at
  shrinking degrees of involvement (tight / elastic / loose). Floated so the
  opening paragraph wraps around it. The .md / llms.txt rendition drops it (see
  COMPONENT_REPLACEMENTS in src/lib/markdown.ts): the LoopSizes diagram right
  below carries the same idea in an agent-legible form.
*/}
<figure class="loops-scene">
  <Image
    src={loopsImg}
    alt="Three pool-noodle loops growing from a small tight black ring to a wide loose silver one, with miniature figures at shrinking degrees of involvement"
    widths={[300, 450, 600]}
    sizes="(max-width: 600px) 100vw, 300px"
    draggable="false"
  />
</figure>

<style>
  /* On mobile the figure is a plain full-width block above the prose. From the
     tablet breakpoint up it floats at the left edge of the 740px reading column
     (the .reading wrapper in the MDX gives it that containing block), so the
     opening paragraphs wrap around it. */
  .loops-scene {
    margin: 0 0 4px;
  }

  .loops-scene :global(img) {
    width: 100%;
    height: auto;
  }

  @media (min-width: 601px) {
    .loops-scene {
      float: left;
      width: 300px;
      margin: 2px 30px 2px 0;
      shape-outside: margin-box;
    }
  }
</style>
