---
import { Image } from 'astro:assets';
import heroImg from '../assets/elastic-loop-hero-2.webp';

interface Props {
  kicker: string;
  title: string;
  tagline: string;
}

const { kicker, title, tagline } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="rg-kicker kicker">{kicker}</div>
      <h1>{title}</h1>
      <p class="tagline">{tagline}</p>
    </div>
    <div class="hero-visual">
      <Image
        src={heroImg}
        alt="Three figures pulling a tangle of tight, elastic and loose loops"
        class="hero-img"
        draggable="false"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 72px 24px 24px;
  }

  .hero-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 720px;
  }

  .kicker {
    margin-bottom: 22px;
  }

  h1 {
    font-size: 72px;
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--rg-fg-1);
    margin: 0 0 22px;
  }

  .tagline {
    font-size: 24px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--rg-fg-2);
    margin: 0;
  }

  .hero-visual {
    margin-top: 24px;
    aspect-ratio: 1240 / 420;
    overflow: hidden;
  }

  .hero-visual :global(img.hero-img) {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center 42%;
  }

  @media (max-width: 860px) {
    .hero-visual {
      aspect-ratio: 1240 / 480;
    }
  }

  @media (max-width: 600px) {
    h1 {
      font-size: clamp(34px, 11vw, 50px);
    }
    .hero-visual {
      aspect-ratio: auto;
      overflow: visible;
    }
    .hero-visual :global(img.hero-img) {
      height: auto;
      object-fit: fill;
    }
  }
</style>
