---
import LoopMark from './visuals/LoopMark.astro';

const navItems = [
  { slug: 'loops', label: 'Loops' },
  { slug: 'why', label: 'Why' },
  { slug: 'harness', label: 'Harness' },
  { slug: 'grading', label: 'Grading' },
  { slug: 'roles', label: 'Roles' },
  { slug: 'faq', label: 'FAQ' },
];

// build.format 'file': pathname can be '/loops' or '/loops.html'
const path = Astro.url.pathname.replace(/\.html$/, '').replace(/\/+$/, '') || '/';
const isActive = (slug: string) => path === `/${slug}`;
---

<header class="masthead">
  <div class="mh-row">
    <a class="wordmark" href="/">
      <LoopMark size={34} />
      <span>The Elastic Loop</span>
    </a>
    <nav class="mh-nav">
      {
        navItems.map((item) => (
          <a
            href={`/${item.slug}`}
            class:list={[{ active: isActive(item.slug) }]}
            aria-current={isActive(item.slug) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="mh-right">
      <a class="mh-ext" href="https://www.robert-glaser.de" target="_blank" rel="noopener">robert-glaser.de&nbsp;&#8599;</a>
      <button class="nav-toggle" type="button" aria-label="Toggle menu" aria-expanded="false">
        <svg class="icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
        <svg class="icon-close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .masthead {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rg-border);
  }

  .mh-row {
    max-width: 1288px;
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--rg-fg-1);
    text-decoration: none;
    white-space: nowrap;
  }
  .wordmark:hover {
    color: var(--rg-accent);
  }
  .wordmark span {
    font-size: 21px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .mh-nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .mh-nav a {
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    color: var(--rg-fg-1);
  }
  .mh-nav a.active {
    color: var(--rg-accent);
  }
  .mh-nav a:hover {
    color: var(--rg-accent);
  }

  .mh-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .mh-ext {
    font-size: 14px;
    font-weight: 400;
    color: var(--rg-fg-3);
    text-decoration: none;
    white-space: nowrap;
  }
  .mh-ext:hover {
    color: var(--rg-accent);
  }

  .nav-toggle {
    display: none;
    background: none;
    border: 1px solid var(--rg-border-strong);
    border-radius: 8px;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    color: var(--rg-fg-1);
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle svg {
    display: block;
  }
  .nav-toggle .icon-close {
    display: none;
  }
  .masthead.nav-open .nav-toggle .icon-open {
    display: none;
  }
  .masthead.nav-open .nav-toggle .icon-close {
    display: block;
  }

  @media (max-width: 860px) {
    .mh-row {
      padding: 0 24px;
      gap: 14px;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .mh-ext {
      display: none;
    }
    .mh-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 6px 20px 14px;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--rg-border);
      box-shadow: 0 14px 26px -18px rgba(21, 23, 26, 0.32);
      display: none;
    }
    .masthead.nav-open .mh-nav {
      display: flex;
    }
    .mh-nav a {
      padding: 13px 2px;
      font-size: 18px;
      border-top: 1px solid var(--rg-border);
    }
  }

  @media (max-width: 600px) {
    .mh-row {
      padding: 0 20px;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('header.masthead');
  const toggle = header?.querySelector<HTMLButtonElement>('.nav-toggle');
  toggle?.addEventListener('click', () => {
    const open = header!.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
