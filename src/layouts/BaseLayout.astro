---
import '../styles/tokens.css';
import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  socialDescription?: string;
  slug: string;
  updated?: Date;
}

const { title, description, socialDescription, slug, updated } = Astro.props;

const SITE_URL = 'https://elastic-loop.robert-glaser.de';
const SITE_NAME = 'The Elastic Loop';
const SITE_TAGLINE = 'A framework for delegating work to machines';
const isIndex = slug === 'index';

// og:title stays short and brand-first; the <title> uses the extra SERP space.
const pageTitle = isIndex ? SITE_NAME : `${title} · ${SITE_NAME}`;
const seoTitle = isIndex ? `${SITE_NAME} · ${SITE_TAGLINE}` : pageTitle;
// og:/twitter: descriptions can be shorter than the SEO meta description so
// social previews do not truncate; fall back to the full description.
const ogDescription = socialDescription ?? description;
const canonical = SITE_URL + (isIndex ? '/' : `/${slug}`);
const markdownHref = isIndex ? '/index.md' : `/${slug}.md`;
const ogImage = `${SITE_URL}/og-image.png`;

const author = {
  '@type': 'Person',
  name: 'Robert Glaser',
  url: 'https://www.robert-glaser.de',
};

const website = {
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL + '/',
};

const jsonLd = isIndex
  ? {
      '@context': 'https://schema.org',
      ...website,
      description,
      author,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      author,
      isPartOf: website,
      ...(updated ? { dateModified: updated.toISOString().slice(0, 10) } : {}),
    };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seoTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={isIndex ? 'website' : 'article'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:alt" content="The Elastic Loop — a framework for everyone delegating work to machines" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="The Elastic Loop — a framework for everyone delegating work to machines" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="text/markdown" href={markdownHref} />
    <link rel="alternate" href="/llms.txt" type="text/plain" title="llms.txt" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-OkPHtiMx4cTJVuTdVPmis.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
  </head>
  <body>
    <Masthead />
    <slot />
    <Footer />
  </body>
</html>
